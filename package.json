{
  "name": "street-guesser",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "jest",
    "test:watch": "jest --watch",
    "doctor:expo": "npm_config_loglevel=error pnpm dlx expo-doctor@latest",
    "doctor:react": "pnpm dlx react-doctor@latest . --verbose --diff",
    "preflight": "pnpm test && pnpm typecheck && pnpm lint:fix && pnpm format:fix && pnpm doctor:react && pnpm doctor:expo",
    "vercel:link": "vercel link",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@tanstack/react-query": "^5.0.0",
    "expo": "~55.0.5",
    "expo-linear-gradient": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.16.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.0.0",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2",
    "vercel": "^50.31.1"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
